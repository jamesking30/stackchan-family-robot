# 仅复制为 .env 后填写；不要把真实密钥提交到 Git。
OPENAI_API_KEY=
# 监听局域网前必须设置管理密钥；设备密钥至少 24 个 ASCII 字符，二者不要相同。
ROBOT_ADMIN_API_KEY=
ROBOT_DEVICE_API_KEY=
ROBOT_DB_PATH=var/stackchan.db
ROBOT_HOST=127.0.0.1
ROBOT_PORT=8765
ROBOT_TIMEZONE=Asia/Shanghai

# 真机联调时将 ROBOT_HOST 改为 0.0.0.0；下列设备 ID 必须与固件配置一致。
STACKCHAN_HOST=
STACKCHAN_DEVICE_ID=stackchan-home-01
OPENCLAW_BASE_URL=http://127.0.0.1:18789
