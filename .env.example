# 仅复制为 .env 后填写；不要把真实密钥提交到 Git。
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
# DeepSeek 不可用时可切换到任意 OpenAI-compatible 的本地模型服务。
ROBOT_LOCAL_LLM_ENABLED=false
ROBOT_LOCAL_LLM_BASE_URL=http://127.0.0.1:8080/v1
ROBOT_LOCAL_LLM_MODEL=mlx-community/Qwen3-4B-Instruct-4bit
ROBOT_LOCAL_LLM_API_KEY=local
# 监听局域网前必须设置管理密钥；设备密钥至少 24 个 ASCII 字符，二者不要相同。
ROBOT_ADMIN_API_KEY=
ROBOT_DEVICE_API_KEY=
ROBOT_DB_PATH=var/stackchan.db
ROBOT_HOST=127.0.0.1
ROBOT_PORT=8765
ROBOT_TIMEZONE=Asia/Shanghai
ROBOT_MDNS_ENABLED=true

# 真机联调时将 ROBOT_HOST 改为 0.0.0.0；下列设备 ID 必须与固件配置一致。
STACKCHAN_HOST=
STACKCHAN_DEVICE_ID=stackchan-home-01
OPENCLAW_BASE_URL=http://127.0.0.1:18789
ROBOT_AVATAR_IDLE_ANIMATION_ENABLED=true
ROBOT_AVATAR_IDLE_MIN_SECONDS=4.5
ROBOT_AVATAR_IDLE_MAX_SECONDS=9.5
# 本地人员朝向：五分钟全局扫描，扫描间隔内低频修正当前目标。
ROBOT_PRESENCE_ENABLED=true
ROBOT_PRESENCE_FACE_MODEL=var/models/mediapipe/blaze_face_short_range.tflite
ROBOT_PRESENCE_MIN_CONFIDENCE=0.55
# 未看到脸但看到肩膀、手臂或躯干时，先推导头部方向再二次确认人脸。
ROBOT_PRESENCE_BODY_GUIDANCE_ENABLED=true
ROBOT_PRESENCE_POSE_MODEL=var/models/mediapipe/pose_landmarker_lite.task
ROBOT_PRESENCE_POSE_MIN_CONFIDENCE=0.45
ROBOT_PRESENCE_BODY_GUIDANCE_SETTLE_SECONDS=0.14
ROBOT_PRESENCE_START_DELAY_SECONDS=5
ROBOT_PRESENCE_SCAN_INTERVAL_SECONDS=300
ROBOT_PRESENCE_TRACKING_INTERVAL_SECONDS=5
ROBOT_PRESENCE_ACTIVE_TRACKING_INTERVAL_SECONDS=0.75
ROBOT_PRESENCE_SCAN_YAW_DEGREES="-40,-20,0,20,40"
ROBOT_PRESENCE_SCAN_PITCH_DEGREES="5,20,35"
ROBOT_PRESENCE_PITCH_DEGREES=10
ROBOT_PRESENCE_SERVO_SPEED=120
ROBOT_PRESENCE_YAW_DIRECTION=1
ROBOT_PRESENCE_PITCH_DIRECTION=1
ROBOT_PRESENCE_TARGET_SWITCH_RATIO=1.25
ROBOT_PRESENCE_WAKE_SEARCH_YAW_OFFSETS="-18,18,-40,40"
ROBOT_PRESENCE_WAKE_SEARCH_PITCH_OFFSETS="-10,10"
ROBOT_PRESENCE_WAKE_SEARCH_SETTLE_SECONDS=0.16
ROBOT_PRESENCE_WAKE_SEARCH_FRAME_TIMEOUT_SECONDS=0.28
ROBOT_PRESENCE_WAKE_SEARCH_BUDGET_SECONDS=0.65
ROBOT_PRESENCE_WAKE_SMOOTH_STEP_DEGREES=6
ROBOT_PRESENCE_WAKE_SMOOTH_STEP_SECONDS=0.06
ROBOT_VOICE_KWS_SCORE=3.0
ROBOT_VOICE_KWS_THRESHOLD=0.12
ROBOT_VOICE_KWS_TARGET_RMS=2800
ROBOT_VOICE_KWS_MAX_GAIN=4.0
ROBOT_VOICE_KWS_MIN_GAIN_RMS=80
ROBOT_CHILD_IDENTITY_ENABLED=true
ROBOT_CHILD_IDENTITY_USER_ID=user-4
ROBOT_CHILD_IDENTITY_DISPLAY_NAME=六六
ROBOT_CHILD_IDENTITY_AGE_MODEL=var/models/insightface/genderage.onnx
ROBOT_CHILD_IDENTITY_MAXIMUM_AGE=11
ROBOT_CHILD_IDENTITY_MINIMUM_PITCH_HZ=260

# M2 语音链路。默认用户为未分配身份，避免在 M3 人脸识别完成前误用成人权限。
ROBOT_VOICE_AUTO_START=true
ROBOT_VOICE_USER_ID=user-2
ROBOT_VOICE_WHISPER_BINARY=whisper-cli
ROBOT_VOICE_WHISPER_SERVER_URL=http://127.0.0.1:8767
ROBOT_VOICE_WHISPER_MODEL=var/models/ggml-small.bin
ROBOT_VOICE_ZH_NAME=Tingting
ROBOT_VOICE_EN_NAME=Samantha
# 主音色：本地 GPT-SoVITS v2；下面的 Qwen 服务作为自动备用。
ROBOT_VOICE_TTS_PROVIDER=gpt_sovits
ROBOT_VOICE_GPT_SOVITS_BASE_URL=http://127.0.0.1:9880
ROBOT_VOICE_GPT_SOVITS_REF_AUDIO=var/models/gpt-sovits/elysia/reference-happy.wav
ROBOT_VOICE_GPT_SOVITS_PROMPT_TEXT=所以你今天就来见我了吗？哇，真令人开心呢。
ROBOT_VOICE_GPT_SOVITS_PROMPT_LANG=zh
ROBOT_VOICE_GPT_SOVITS_SPEED=1.10
ROBOT_VOICE_TTS_BASE_URL=http://127.0.0.1:8766
ROBOT_VOICE_TTS_MODEL=mlx-community/Qwen3-TTS-12Hz-0.6B-CustomVoice-8bit
ROBOT_VOICE_TTS_SPEAKER=Vivian
ROBOT_VOICE_TTS_INSTRUCTION=明亮、轻快、灵动、有精神，语速稍快，停顿简洁；保持亲切俏皮，不要慵懒拖音，不要急促，不要尖叫或夸张卖萌。
ROBOT_VOICE_TTS_SPEED=1.10
ROBOT_VOICE_TTS_FALLBACK_TO_SYSTEM=true
ROBOT_VOICE_SILENCE_MS=600
ROBOT_VOICE_DEVICE_VAD_ENABLED=true
ROBOT_VOICE_DEVICE_VAD_HANGOVER_MS=240
# Silero 仅识别人声，与设备 VAD、能量门限和舵机噪声门控共同判定。
ROBOT_VOICE_SILERO_VAD_ENABLED=true
ROBOT_VOICE_SILERO_VAD_MODEL=var/models/silero_vad.onnx
ROBOT_VOICE_SILERO_VAD_THRESHOLD=0.50
ROBOT_VOICE_LATENCY_HISTORY=var/health/voice-latency.jsonl
ROBOT_VOICE_LATENCY_MAX_SAMPLES=200
ROBOT_VOICE_SERVO_NOISE_GUARD_MS=320
ROBOT_VOICE_MIN_SPEECH_MS=300
ROBOT_VOICE_MAX_SPEECH_SECONDS=15
ROBOT_VOICE_WAKE_WORD=爱莉
# Whisper 可能使用同音字或拼音转写唤醒词。
ROBOT_VOICE_WAKE_ALIASES="艾莉,爱丽,艾丽,爱里,爱莉希雅,Ai Li,Aili,Ali,Ally,Eli,Ellie"
ROBOT_VOICE_WAKE_SESSION_SECONDS=18
ROBOT_VOICE_SLEEP_PHRASES=再见,休息吧,不用了
ROBOT_VOICE_WAKE_ACK_PCM=var/cache/voice/wake-ack-v3.wav
